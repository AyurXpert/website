  "exam_guide": {
    "title": "Shwasa / Respiratory — Examination Protocol",
    "steps": [
      {
        "step": 1, "title": "Inspection (Darshana — Chest & Breathing)",
        "items": ["Respiratory rate (normal 12–20/min; >25 = significant distress)", "Accessory muscle use — sternocleidomastoid, scalenes, intercostals (severe obstruction)", "Pursed-lip breathing — COPD pattern (auto-PEEP)", "Paradoxical breathing — diaphragmatic fatigue", "Chest shape — barrel (COPD / hyperinflation), pigeon, kyphoscoliosis", "Intercostal recession, tracheal tug"]
      },
      {
        "step": 2, "title": "Palpation (Sparsha)",
        "items": ["Tracheal position — midline vs deviated (effusion pushes away, fibrosis/collapse pulls toward)", "Chest expansion — both hands on lower chest; normal >5 cm symmetric expansion", "Vocal fremitus — increased (consolidation), decreased (effusion/pneumothorax)", "Rib tenderness (fracture / Tietze)"]
      },
      {
        "step": 3, "title": "Percussion",
        "items": ["Resonant (normal lung)", "Hyper-resonant (emphysema, pneumothorax)", "Stony dull (pleural effusion)", "Dull (consolidation, collapse, mass)", "Liver/cardiac dullness position — check for hyperinflation (pushing down)"]
      },
      {
        "step": 4, "title": "Auscultation (Shravana)",
        "items": ["Vesicular breath sounds (normal) — soft, inspiratory-predominant", "Bronchial breath sounds — consolidation, cavity", "Wheeze (Ronchi) — expiratory = lower airway obstruction (asthma/COPD)", "Fine crackles — ILD, pulmonary oedema (Kaphadhikya)", "Coarse crackles — bronchiectasis, retained secretions", "Pleural rub — pleuritis, pleural effusion"]
      },
      {
        "step": 5, "title": "Pranavaha Srotas Pariksha (Ayurveda)",
        "items": ["Shwasa observation — count rate; note depth, regularity, nostril dominance", "Pranayama capacity test — ask patient to take a deep breath; note wheeze on forced expiration", "Kantha (throat) — dryness, hoarseness (Vataja), phlegm (Kaphaja), burning (Pittaja)", "Nadi — Vata-Kapha (irregular, slow, heavy) in Tamaka Shwasa", "Ama signs — white tongue coating, heaviness, morning chest tightness worse (Kaphaja Ama)"]
      },
      {
        "step": 6, "title": "Peak Flow / SpO₂ Measurement",
        "items": ["SpO₂ resting (normal ≥95%; <90% = significant hypoxia)", "SpO₂ on exertion — 6-minute walk test drop >4% = significant", "PEFR — three attempts, record best (compare to predicted by age/height/gender)", "Diurnal variation >20% = asthma (morning dip characteristic of Tamaka Shwasa)"]
      }
    ],
    "reference_values": [
      { "test": "SpO₂", "unit": "%", "normal": "≥95", "borderline": "92–94 (monitor closely)", "abnormal": "<92 (supplemental O₂ / urgent review)" },
      { "test": "FEV₁/FVC ratio", "unit": "ratio", "normal": "≥0.70 (no obstruction)", "borderline": "0.60–0.69 (mild obstruction)", "abnormal": "<0.60 (moderate–severe obstruction)" },
      { "test": "FEV₁ % predicted", "unit": "%", "normal": "≥80", "borderline": "60–79 (mild–moderate)", "abnormal": "<60 (severe obstruction)" },
      { "test": "PEFR % predicted", "unit": "%", "normal": "≥80", "borderline": "60–80 (yellow zone)", "abnormal": "<60 (red zone — act)" },
      { "test": "RR (adult)", "unit": "/min", "normal": "12–20", "borderline": "21–25 (mild tachypnoea)", "abnormal": ">25 (respiratory distress)" }
    ]
  }
}
