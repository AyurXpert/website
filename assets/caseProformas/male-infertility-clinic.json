  "exam_guide": {
    "title": "Vandhyatva / Klaibya — Examination Protocol",
    "steps": [
      {
        "step": 1, "title": "General Inspection & Body Habitus",
        "items": ["Body build — eunuchoidal (span > height, pubis-floor > pubis-crown = hypogonadism)", "BMI, waist-hip ratio (central obesity = Medaroga = low testosterone)", "Hair distribution — axillary, pubic, facial (reduced = hypogonadism)", "Gynaecomastia — breast tissue enlargement (hyperprolactinaemia, oestrogen excess, Klinefelter)", "Skin — acne, oiliness (androgen excess vs deficiency)"]
      },
      {
        "step": 2, "title": "Genital Examination (Upastha Pariksha)",
        "items": ["Penis — size, phimosis, hypospadias, chordee, Peyronie's plaques (hard cord on shaft)", "Testes — volume (orchidometer: normal >15mL adult), consistency (firm = normal, soft/small = atrophy)", "Epididymis — fullness (obstruction), tenderness (epididymo-orchitis), cyst", "Vas deferens — palpable bilaterally (absent vas = CBAVD — cystic fibrosis related)", "Varicocele — examine standing + Valsalva (grade 1: palpable on Valsalva; grade 3: visible 'bag of worms')"]
      },
      {
        "step": 3, "title": "Neurological Assessment (ED related)",
        "items": ["Bulbocavernosus reflex — squeeze glans, feel anal contraction (S3-S4 integrity)", "Perineal sensation — saddle area (pudendal nerve)", "Lower limb reflexes — patellar, Achilles (peripheral neuropathy in DM)", "Blood pressure — lying + standing (autonomic neuropathy = postural drop >20/10mmHg)"]
      },
      {
        "step": 4, "title": "Nadi Pariksha — Shukra Dhatu",
        "items": ["Nadi quality in Vataja Klaibya — thin, irregular, moving like a leech (Jalachara)", "Nadi in Kaphaja Klaibya — slow, heavy, cool, uniform (Hamsa/Manduka gati)", "Nadi in Pittaja — forceful, hot, irritable (Sarpa gati)", "Shukra Nadi — assess at 3rd finger position (Kapha finger — Shukra Sthana)", "Bala (vitality) from Nadi — thin/feeble = Kshaya; full/regular = good reserve"]
      },
      {
        "step": 5, "title": "Systemic Review Points",
        "items": ["Blood pressure — hypertension is major cause of vasculogenic ED", "Cardiovascular — ED is often the first sign of cardiovascular disease (arterial insufficiency)", "Prostate — DRE in men >40 years (enlarged/nodular = BPH / CaP; affects ejaculation)", "Thyroid — goitre, tremor (hyperthyroidism → ED; hypothyroidism → low testosterone)"]
      }
    ],
    "reference_values": [
      { "test": "Semen Volume", "unit": "mL", "normal": "≥1.4", "borderline": "1.0–1.3 (hypospermia)", "abnormal": "<1.0 (retrograde / obstruction)" },
      { "test": "Sperm Concentration", "unit": "×10⁶/mL", "normal": "≥16", "borderline": "5–15 (mild oligospermia)", "abnormal": "<5 (severe oligospermia)" },
      { "test": "Progressive Motility (PR)", "unit": "%", "normal": "≥30", "borderline": "20–29", "abnormal": "<20 (asthenospermia)" },
      { "test": "Total Testosterone", "unit": "ng/dL", "normal": "≥300 (400–800 optimal)", "borderline": "200–299 (borderline low)", "abnormal": "<200 (hypogonadism — treat)" },
      { "test": "FSH (azoospermia)", "unit": "IU/L", "normal": "<7.6 (obstructive azoospermia likely)", "borderline": "7.6–12 (check biopsy)", "abnormal": ">12 (non-obstructive — Sertoli only / Klinefelter)" }
    ]
  }
}
