          "options": ["Foods (Viruddha Ahara)", "Stress (Manasika)", "Sun exposure", "Cold / humidity", "Chemicals / soap / detergent", "Infection (fungal / bacterial)", "Drugs / medications", "Hormonal changes", "Unknown"] },
        { "id": "skin_notes", "label": "Clinical Notes / Treatment History", "type": "textarea",
          "placeholder": "Previous treatments, response to therapy, Shodhana history, Lepas used…" }
      ]
    }
  ],
  "exam_guide": {
    "title": "Kushtha / Skin — Examination Protocol",
    "steps": [
      {
        "step": 1, "title": "Darshana — Systematic Skin Survey",
        "items": ["Good lighting (natural preferred)", "Examine head to toe — scalp, face, oral mucosa, trunk, limbs, palms, soles, nails, genitalia", "Document distribution: localised / regional / generalised / flexural / extensor / dermatomal", "Note primary lesion type: macule, papule, plaque, vesicle, bulla, pustule, nodule, wheal", "Note secondary changes: scaling, crust, erosion, ulcer, lichenification, pigment change"]
      },
      {
        "step": 2, "title": "Twak Pariksha — Sparsha (Palpation)",
        "items": ["Temperature — warm (Pitta/infected), cool (Vata/ischaemic)", "Texture — rough/dry (Vata-Kushtha), smooth/oily (Kapha-Kushtha)", "Tenderness on palpation (Pitta)", "Scale character — fine/pityriasiform, silvery (psoriasis), lamellar", "Induration / infiltration depth", "Diascopy — blanches (vascular) vs persists (purpura / fixed drug)"]
      },
      {
        "step": 3, "title": "Special Examinations",
        "items": ["Köbner phenomenon — scratch test for psoriasis / lichen planus", "Nikolsky sign — gentle pressure separates epidermis (pemphigus)", "Wood's lamp (UV) — ash-leaf white (tuberous sclerosis), coral-red (erythrasma), yellow-green (tinea versicolor)", "KOH mount — skin scraping for fungal hyphae (before antifungal treatment)", "Dermoscopy — pigmented lesions, dermoscopic features"]
      },
      {
        "step": 4, "title": "Nails & Hair (Nakha-Kesha Pariksha)",
        "items": ["Nail pitting, onycholysis, subungual hyperkeratosis (psoriasis)", "Nail discolouration — yellow (fungal), white (Terry's), koilonychia (Fe deficiency)", "Hair loss pattern — diffuse, patterned, alopecia areata (patch)", "Scalp — scaling, inflammation, folliculitis"]
      },
      {
        "step": 5, "title": "Lymph Nodes & Systemic",
        "items": ["Regional lymphadenopathy (inflammatory / malignant)", "Mucous membranes — oral ulcers (Behcet's, SLE), Wickham's striae (lichen planus)", "Joints — psoriatic arthritis screen (Sandhishula + skin)"]
      }
    ],
    "reference_values": [
      { "test": "PASI Score", "unit": "0–72", "normal": "0 (clear)", "borderline": "1–10 (mild)", "abnormal": ">10 moderate / >20 severe" },
      { "test": "DLQI", "unit": "0–30", "normal": "0–1 (no effect)", "borderline": "2–10 (small–moderate effect)", "abnormal": ">10 (large–very large effect)" },
      { "test": "SCORAD (Eczema)", "unit": "0–103", "normal": "0 (clear)", "borderline": "<25 mild / 25–50 moderate", "abnormal": ">50 severe" }
    ]
  }
}
